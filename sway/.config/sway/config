# copy-paste containers between workspaces
bindsym $mod+c mark i3-copy
#bindsym $mod+v mark i3-paste; [con_mark="i3-copy"] move container to mark i3-paste; unmark i3-copy; unmark i3-paste
bindsym $mod+v exec sh -c 'swaymsg [con_mark="i3-copy"] move container to workspace $(swaymsg -t get_workspaces -r | jq -r ".[] | select(.focused).name"); swaymsg unmark i3-copy'

# move workspaces between monitors
bindsym $mod+Left move workspace to output left
bindsym $mod+Right move workspace to output right

# move container to new workspace
