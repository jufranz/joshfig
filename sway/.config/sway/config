set $mod Mod4

# Display setup
output * disable
output DP-1 {
  mode 3840x2160@144Hz
  pos 3840 0
  bg /usr/share/backgrounds/IMG_3918.jpg fill
  enable
}
output DP-3 {
  mode 3840x2160@144Hz
  pos 0 0
  bg /usr/share/backgrounds/IMG_3918.jpg fill
  enable
}
exec_always swayidle -w \
  timeout 300 'swaymsg "output * power off"' \
  resume 'swaymsg "output * power on"'

# Notification setup
exec swaync
bindsym $mod+Tab exec swaync-client -t

# Export variables to systemd / dbus activation environments
# https://github.com/swaywm/sway/wiki#systemd-and-dbus-activation-environments
exec systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP SWAYSOCK I3SOCK XCURSOR_SIZE XCURSOR_THEME

# Window gaps setup
gaps inner 50

# --- Window Colors ---
# class                 border  bground text    indicator child_border
client.focused          #3b5240 #3b5240 #f8f8f2 #3b5240   #3b5240
client.focused_inactive #44475a #44475a #f8f8f2 #44475a   #44475a
client.unfocused        #282a36 #282a36 #bfbfbf #282a36   #282a36
client.urgent           #ff5555 #ff5555 #f8f8f2 #ff5555   #ff5555

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
#font pango:monospace 16
font pango:Roboto, FontAwesome 16

# This font is widely installed, provides lots of unicode glyphs, right-to-left
# text rendering and scalability on retina/hidpi displays (thanks to pango).
#font pango:DejaVu Sans Mono 8

